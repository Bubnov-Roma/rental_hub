{
  "name": "rental_hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:fix": "biome check --fix --unsafe .",
    "type-check": "tsc --noEmit --skipLibCheck",
    "commit": "cz",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run type-check && npm run format:check && npm run lint",
    "check:ci": "npm run type-check && npm run lint && npm run test:ci",
    "analyze": "ANALYZE=true next build",
    "size": "size-limit",
    "clean": "rm -rf .next node_modules/.cache",
    "fresh": "npm run clean && npm install",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "analyze:bundle": "ANALYZE=true npm run build",
    "analyze:size": "npx @next/bundle-analyzer",
    "gen:component": "node scripts/generate-component.js",
    "gen:page": "node scripts/generate-page.js",
    "docs": "typedoc --out docs src",
    "docs:serve": "serve docs",
    "migrate": "npx supabase db push",
    "migrate:status": "npx supabase db status",
    "backup:db": "node scripts/backup-database.js",
    "clear:cache": "rm -rf .next/cache",
    "clear:all": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@vercel/speed-insights": "^1.3.1",
    "add": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "input-otp": "^1.4.2",
    "js-cookie": "^3.0.5",
    "lodash.set": "^4.3.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.1",
    "react-number-format": "^5.4.4",
    "react-phone-number-input": "^3.4.14",
    "shadcn": "^3.8.0",
    "simple-icons": "^16.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tooltip": "^1.6.1",
    "use-debounce": "^10.1.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash.set": "^4.3.9",
    "@types/node": "^25.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "depcheck": "^1.4.7",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "npm-check-updates": "^19.3.2",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
