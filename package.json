{
  "name": "rental_hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:fix": "biome check --fix --unsafe .",
    "type-check": "tsc --noEmit --skipLibCheck",
    "commit": "cz",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run type-check && npm run format:check && npm run lint",
    "check:ci": "npm run type-check && npm run lint && npm run test:ci",
    "analyze": "ANALYZE=true next build",
    "size": "size-limit",
    "clean": "rm -rf .next node_modules/.cache",
    "fresh": "npm run clean && npm install",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "analyze:bundle": "ANALYZE=true npm run build",
    "analyze:size": "npx @next/bundle-analyzer",
    "gen:component": "node scripts/generate-component.js",
    "gen:page": "node scripts/generate-page.js",
    "docs": "typedoc --out docs src",
    "docs:serve": "serve docs",
    "migrate": "npx supabase db push",
    "migrate:status": "npx supabase db status",
    "backup:db": "node scripts/backup-database.js",
    "clear:cache": "rm -rf .next/cache",
    "clear:all": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.88.0",
    "@tanstack/react-query": "^5.90.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-datepicker": "^9.0.0",
    "react-day-picker": "^9.12.0",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.68.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.9",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.27",
    "@types/react": "^19",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.0.1",
    "depcheck": "^1.4.7",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "npm-check-updates": "^19.2.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
