// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────

enum Role {
  GUEST
  USER
  PARTNER
  MANAGER
  ADMIN
}

enum EntityType {
  INDIVIDUAL
  INDIVIDUAL_PARTNER
  LEGAL_ENTITY
  LEGAL_PARTNER
}

enum BookingStatus {
  PENDING_REVIEW
  WAIT_PAYMENT
  READY_TO_RENT
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum EquipmentStatus {
  AVAILABLE
  RENTED
  RESERVED
  MAINTENANCE
  BROKEN
  RETIRED
}

enum OwnershipType {
  INTERNAL
  SUBLEASE
}

enum DiscountType {
  PERCENT
  FIXED
  PROMO
}

enum ApplicationStatus {
  LOADING
  NO_APPLICATION
  DRAFT
  PENDING
  REVIEWING
  CLARIFICATION
  STANDARD
  APPROVED
  REJECTED
  BLOCKED
}

enum HistoryAction {
  CREATED
  UPDATED
  DELETED
}

enum CategoryEntityType {
  CATEGORY
  SUBCATEGORY
}

// ─── NEXTAUTH & PROFILES ───────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role                Role        @default(USER)
  entityType          EntityType? @default(INDIVIDUAL)
  companyName         String?
  tin                 String?
  isVerified          Boolean?    @default(false)
  phone               String?
  extraPhone          String?
  registrationStep    Int         @default(1)
  nickname            String?
  isBlocked           Boolean     @default(false)
  blockedReason       String?
  permissions         Json        @default("{}")
  deletionScheduledAt DateTime?
  createdAt           DateTime    @default(now())

  accounts           Account[]
  sessions           Session[]
  bookings           Booking[]
  cartItems          CartItem[]
  favorites          Favorite[]
  equipmentSets      EquipmentSet[]
  clientApplication  ClientApplication?
  adminNotifications AdminNotification[]
  categoryHistory    CategoryHistory[]
  userDiscounts      UserDiscount[]       @relation("DiscountUser")
  createdDiscounts   UserDiscount[]       @relation("DiscountCreator")
  faqCreated         FaqItem[]            @relation("FaqCreator")
  faqUpdated         FaqItem[]            @relation("FaqUpdater")
  notesReceived      UserAdminNote[]      @relation("NoteTarget")
  notesWritten       UserAdminNote[]      @relation("NoteAuthor")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? 
  access_token      String? 
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? 
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── MAIN DOMAIN ─────────────────────────────────────────────────────────────

model ClientApplication {
  id              String            @id @default(uuid())
  userId          String            @unique
  clientType      String
  applicationData Json              @default("{}")
  status          ApplicationStatus @default(DRAFT)
  rejectionReason String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Booking {
  id                    String        @id @default(uuid())
  userId                String
  startDate             DateTime
  endDate               DateTime
  totalAmount           Float
  status                BookingStatus @default(PENDING_REVIEW)
  totalReplacementValue Float?        @default(0)
  insuranceIncluded     Boolean?      @default(true)
  cancellationReason    String?
  cancelledAt           DateTime?
  expiredAt             DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  bookingItems BookingItem[]
}

model BookingItem {
  id                        String   @id @default(uuid())
  bookingId                 String
  equipmentId               String
  priceAtBooking            Float
  depositAtBooking          Float?   @default(0)
  replacementValueAtBooking Float?   @default(0)

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
}

model Equipment {
  id               String          @id @default(uuid())
  title            String
  slug             String          @unique
  description      String?
  pricePerDay      Float
  price4h          Float           @default(0)
  price8h          Float           @default(0)
  deposit          Float           @default(0)
  replacementValue Float           @default(0)

  categoryId       String          
  subcategoryId    String?         
  
  isAvailable      Boolean         @default(true)
  isPrimary        Boolean         @default(false)
  status           EquipmentStatus @default(AVAILABLE)
  inventoryNumber  String?
  defects          String?
  kit              String?
  kitDescription   String?
  ownershipType    OwnershipType   @default(INTERNAL)
  partnerName      String?
  specifications   Json            @default("{}")
  comments         Json            @default("[]")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory      Subcategory?    @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  relatedEquipment EquipmentRelation[] @relation("EquipmentToRelated")
  relatedTo        EquipmentRelation[] @relation("RelatedToEquipment")

  bookingItems        BookingItem[]
  cartItems           CartItem[]
  favorites           Favorite[]
  equipmentImageLinks EquipmentImageLink[]
}

model EquipmentRelation {
  id          String @id @default(uuid())
  equipmentId String
  relatedId   String

  equipment Equipment @relation("EquipmentToRelated", fields: [equipmentId], references: [id], onDelete: Cascade)
  related   Equipment @relation("RelatedToEquipment", fields: [relatedId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, relatedId])
}

model Category {
  id            String  @id @default(uuid())
  name          String
  slug          String  @unique
  iconName      String  @default("Package")
  sortOrder     Int     @default(0)
  adminNotes    String?
  imageUrl      String?
  isModular     Boolean @default(false)

  subcategories Subcategory[]
  equipments    Equipment[]
}

model Subcategory {
  id         String  @id @default(uuid())
  categoryId String
  name       String
  slug       String  @unique
  sortOrder  Int     @default(0)
  adminNotes String?
  imageUrl   String?

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  equipments Equipment[]
}

model Image {
  id   String  @id @default(uuid())
  url  String
  hash String? @unique

  equipmentImageLinks EquipmentImageLink[]
}

model EquipmentImageLink {
  id          String @id @default(uuid())
  equipmentId String
  imageId     String
  orderIndex  Int    @default(0)

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  image     Image     @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, imageId])
}

model CartItem {
  id                String    @id @default(uuid())
  userId            String
  equipmentId       String
  quantity          Int       @default(1)
  addedAt           DateTime  @default(now())
  bookedAt          DateTime?
  prepaidAt         DateTime?
  fullyPaidAt       DateTime?
  depositPaidAt     DateTime?
  depositReturnedAt DateTime?
  depositAmount     Float?    @default(0)
  completedAt       DateTime?
  cancelledAt       DateTime?
  changeLog         Json      @default("[]")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  @@unique([userId, equipmentId])
}

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  equipmentId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

model EquipmentSet {
  id              String   @id @default(uuid())
  userId          String
  name            String
  description     String?
  items           Json     @default("[]")
  totalPricePerDay Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminNotification {
  id        String   @id @default(uuid())
  type      String
  userId    String?
  payload   Json     @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CategoryHistory {
  id         String             @id @default(uuid())
  entityType CategoryEntityType
  entityId   String
  action     HistoryAction
  changedBy  String?
  changes    Json?
  changedAt  DateTime           @default(now())

  user User? @relation(fields: [changedBy], references: [id], onDelete: SetNull)
}

model FaqItem {
  id         String   @id @default(uuid())
  question   String
  answer     String
  sortOrder  Int      @default(0)
  category   String?
  isActive   Boolean  @default(true)
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author  User? @relation("FaqCreator", fields: [createdBy], references: [id])
  updater User? @relation("FaqUpdater", fields: [updatedBy], references: [id])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserAdminNote {
  id        String   @id @default(uuid())
  userId    String
  authorId  String?
  note      String
  createdAt DateTime @default(now())

  targetUser User  @relation("NoteTarget", fields: [userId], references: [id], onDelete: Cascade)
  author     User? @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

model UserDiscount {
  id          String       @id @default(uuid())
  userId      String
  type        DiscountType
  value       Float        @default(0)
  promoCode   String?
  description String?
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean      @default(true)
  createdBy   String?
  createdAt   DateTime     @default(now())

  user    User  @relation("DiscountUser", fields: [userId], references: [id], onDelete: Cascade)
  creator User? @relation("DiscountCreator", fields: [createdBy], references: [id], onDelete: SetNull)
}